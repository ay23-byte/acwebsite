# ============================================
# AC Website - Environment Variables
# ============================================
# Copy this file to .env.local and fill in your values

# ============================================
# 1. DATABASE CONFIGURATION (REQUIRED)
# ============================================
# Option A: Local MongoDB
# MONGODB_URI=mongodb://localhost:27017/ac-website

# Option B: MongoDB Atlas (Cloud) - RECOMMENDED FOR PRODUCTION
# Steps:
# 1. Go to https://www.mongodb.com/cloud/atlas
# 2. Create free account
# 3. Create new cluster
# 4. Click "Connect" → "Drivers"
# 5. Copy connection string
# 6. Replace <username>, <password>, <cluster>
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/ac_booking?retryWrites=true&w=majority

# ============================================
# 2. AUTHENTICATION (REQUIRED)
# ============================================
# Generate a secret: openssl rand -base64 32
NEXTAUTH_SECRET=your-super-secret-key-change-this-in-production
NEXTAUTH_URL=http://localhost:3000

# ============================================
# 3. APP CONFIGURATION (REQUIRED FOR PRODUCTION)
# ============================================
# Your production domain URL
NEXT_PUBLIC_DOMAIN=https://airprocooling.com

# ============================================
# 4. ANALYTICS (OPTIONAL)
# ============================================
# Google Analytics - Get from https://analytics.google.com
# Format: G_XXXXXXXXXX
NEXT_PUBLIC_GOOGLE_ANALYTICS=G_XXXXXXXXXX

# ============================================
# 5. EMAIL CONFIGURATION (OPTIONAL)
# ============================================
# For booking notifications and admin alerts
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
ADMIN_EMAIL=admin@airprocooling.com

# ============================================
# 6. BUSINESS CONTACT (USED IN CONFIG)
# ============================================
# Primary phone number for bookings
NEXT_PUBLIC_PHONE=6393997891

# WhatsApp Business Number (can be same as phone)
NEXT_PUBLIC_WHATSAPP_PHONE=6393997891

# ============================================
# PRODUCTION DEPLOYMENT TIPS
# ============================================
# 1. Never commit .env.local to git (it's in .gitignore)
# 2. Set environment variables in your hosting:
#    - Vercel: Dashboard → Settings → Environment Variables
#    - Docker: docker-compose.yml or .env file
#    - Traditional: Use hosting control panel
# 3. Use strong, unique passwords for MongoDB
# 4. Enable SSL/TLS for all connections (Vercel does this automatically)
# 5. Test on staging before deploying to production
# 6. Change NEXTAUTH_SECRET to a strong random value in production
